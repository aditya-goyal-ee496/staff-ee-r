# Copy to .env (git-ignored) and fill in. Never commit real secrets.

# OpenRouter API key for the LLM reasoner (slice 06 / Track E). Leave blank until needed.
OPENROUTER_API_KEY=

# Path to the demand-supply workbook. When unset, defaults to the bundled
# planning/raw-data/demand-supply.xlsx if present (the CLI loads this .env on startup).
# STAFFEER_DATA=planning/raw-data/demand-supply.xlsx

# Path to the Milvus Lite vector DB for semantic retrieval. Required by `match --semantic`
# and `make index`: set this, run `make index` to build embeddings, then pass `--semantic`.
# STAFFEER_MILVUS_PATH=.staffeer/semantic-index.db

# Path to the profiles directory. Defaults to bundled profiles dir when present; used by
# `staffeer index` to embed profile text.
# STAFFEER_PROFILES_DIR=planning/raw-data/profiles

# Flag to enable profile loading and embedding. Defaults to false.
# STAFFEER_PROFILES=true
